{
  "default_interface": "eth0",
  "default_probe_command": "",
  "cases": [
    {
      "name": "sip-tcp-delay-jitter",
      "link": "SIP_TCP",
      "interface": "eth0",
      "target_port": 5060,
      "protocol": "tcp",
      "condition": { "delay_ms": 120, "jitter_ms": 30 }
    },
    {
      "name": "rtp-udp-loss-reorder",
      "link": "RTP_UDP",
      "interface": "eth0",
      "target_port": 46000,
      "protocol": "udp",
      "condition": { "loss_percent": 5, "reorder_percent": 20 }
    },
    {
      "name": "rtp-tcp-disconnect",
      "link": "RTP_TCP",
      "interface": "eth0",
      "target_port": 46000,
      "protocol": "tcp",
      "condition": { "disconnect_ms": 3000 }
    },
    {
      "name": "rtp-udp-bandwidth-shrink",
      "link": "RTP_UDP",
      "interface": "eth0",
      "target_port": 46000,
      "protocol": "udp",
      "condition": { "bandwidth_kbps": 512 }
    }
  ]
}
