  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum(siptunnel_sip_tcp_current_connections{job=\"siptunnel-gateway\",instance=~\"$instance\"})",
          "legendFormat": "当前连接",
          "refId": "A"
        },
        {
          "expr": "sum(rate(siptunnel_sip_tcp_connection_errors_total{job=\"siptunnel-gateway\",instance=~\"$instance\"}[5m]))",
          "legendFormat": "连接错误速率",
          "refId": "B"
        },
        {
          "expr": "sum(rate(siptunnel_sip_tcp_read_timeout_total{job=\"siptunnel-gateway\",instance=~\"$instance\"}[5m]))",
          "legendFormat": "读超时速率",
          "refId": "C"
        }
      ],
      "title": "SIP TCP 面板",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum(siptunnel_rtp_active_transfers{job=\"siptunnel-gateway\",instance=~\"$instance\"})",
          "legendFormat": "活跃传输",
          "refId": "A"
        },
        {
          "expr": "sum(siptunnel_rtp_port_pool_used{job=\"siptunnel-gateway\",instance=~\"$instance\"})",
          "legendFormat": "端口池占用",
          "refId": "B"
        },
        {
          "expr": "sum(rate(siptunnel_transport_tcp_write_errors_total{job=\"siptunnel-gateway\",instance=~\"$instance\"}[5m]))",
          "legendFormat": "TCP 写错误速率",
          "refId": "C"
        },
        {
          "expr": "sum(increase(siptunnel_rtp_port_alloc_fail_total{job=\"siptunnel-gateway\",instance=~\"$instance\"}[5m]))",
          "legendFormat": "端口分配失败(5m)",
          "refId": "D"
        }
      ],
      "title": "RTP UDP/TCP 面板",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(siptunnel_task_total{job=\"siptunnel-gateway\",instance=~\"$instance\",status=\"failed\"}[10m])) / clamp_min(sum(rate(siptunnel_task_total{job=\"siptunnel-gateway\",instance=~\"$instance\"}[10m])), 0.001)",
          "legendFormat": "任务失败率",
          "refId": "A"
        },
        {
          "expr": "sum(siptunnel_task_inflight{job=\"siptunnel-gateway\",instance=~\"$instance\"})",
          "legendFormat": "处理中任务",
          "refId": "B"
        }
      ],
      "title": "任务面板",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "decbytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(siptunnel_file_transfer_bytes_total{job=\"siptunnel-gateway\",instance=~\"$instance\",direction=\"tx\"}[5m]))",
          "legendFormat": "发送吞吐",
          "refId": "A"
        },
        {
          "expr": "sum(rate(siptunnel_file_transfer_bytes_total{job=\"siptunnel-gateway\",instance=~\"$instance\",direction=\"rx\"}[5m]))",
          "legendFormat": "接收吞吐",
          "refId": "B"
        },
        {
          "expr": "sum(siptunnel_file_transfer_active{job=\"siptunnel-gateway\",instance=~\"$instance\"})",
          "legendFormat": "活跃文件任务",
          "refId": "C"
        }
      ],
      "title": "文件传输面板",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "id": 5,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(siptunnel_rate_limit_hits_total{job=\"siptunnel-gateway\",instance=~\"$instance\"}[5m]))",
          "legendFormat": "限流命中速率",
          "refId": "A"
        },
        {
          "expr": "sum(rate(siptunnel_errors_total{job=\"siptunnel-gateway\",instance=~\"$instance\"}[5m])) by (code)",
          "legendFormat": "错误 {{code}}",
          "refId": "B"
        },
        {
          "expr": "sum(increase(siptunnel_transport_recovery_failed_total{job=\"siptunnel-gateway\",instance=~\"$instance\"}[10m]))",
          "legendFormat": "恢复失败数(10m)",
          "refId": "C"
        },
        {
          "expr": "100 * (1 - avg(node_filesystem_avail_bytes{job=\"node-exporter\",mountpoint=\"/var/lib/siptunnel\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{job=\"node-exporter\",mountpoint=\"/var/lib/siptunnel\",fstype!~\"tmpfs|overlay\"}))",
          "legendFormat": "数据目录使用率%",
          "refId": "D"
        }
      ],
      "title": "限流与错误面板",
      "type": "timeseries"
    }
  ],
